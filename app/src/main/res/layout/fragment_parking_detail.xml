<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_circle_white"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/azul_oscuro"/>

        <!-- CONTENIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- NOMBRE -->
            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parking Central"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/azul_oscuro"/>

            <!-- DIRECCIÓN -->
            <TextView
                android:id="@+id/tvDireccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Calle 80 #15-20"
                android:textSize="15sp"
                android:textColor="#666666"
                android:layout_marginTop="8dp"/>

            <!-- DISPONIBILIDAD -->
            <TextView
                android:id="@+id/tvCupos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢 12 cupos disponibles"
                android:textSize="15sp"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <!-- PRECIO -->
            <TextView
                android:id="@+id/tvPrecio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$4.000 / hora"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/azul_medio"
                android:layout_marginTop="14dp"/>

            <!-- DESCRIPCIÓN -->
            <TextView
                android:id="@+id/tvDescripcion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parqueadero seguro con vigilancia 24 horas, cámaras de seguridad y acceso rápido."
                android:textColor="#555555"
                android:textSize="15sp"
                android:layout_marginTop="18dp"
                android:lineSpacingExtra="4dp"/>

            <!-- CARACTERÍSTICAS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Características"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/azul_oscuro"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"/>

            <!-- CHIPS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24/7"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_chip"
                    android:textColor="@color/azul_oscuro"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vigilado"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:background="@drawable/bg_chip"
                    android:textColor="@color/azul_oscuro"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp"/>

            </LinearLayout>

            <!-- BOTÓN -->
            <Button
                android:id="@+id/btnReservar"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="30dp"
                android:text="Reservar ahora"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/azul_medio"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>