<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--  BARRA SUPERIOR NEGRA -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/detalle_reserva"
        android:textColor="@android:color/white"
        android:background="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!--  CARD PRINCIPAL -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- HEADER AZUL -->
                <TextView
                    android:text="@string/informaci_n_de_la_reserva"
                    android:textColor="@android:color/white"
                    android:background="@color/primary"
                    android:padding="12dp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- CÓDIGO -->
                <TextView
                    android:id="@+id/tvCodigo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pkn_0000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="12dp" />

                <!-- CLIENTE -->
                <TextView
                    android:id="@+id/tvCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cliente"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" />

                <!-- ESTADO -->
                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/estado"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:layout_marginTop="6dp" />

                <!-- SEPARADOR -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gray_border"
                    android:layout_marginTop="14dp" />

                <!-- DETALLES -->
                <TextView
                    android:id="@+id/tvDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/parqueadero_espacio_hora"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="10dp" />

                <!-- BOTÓN -->
                <Button
                    android:id="@+id/btnEditar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/editar_reserva"
                    android:backgroundTint="@color/primary"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="18dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>