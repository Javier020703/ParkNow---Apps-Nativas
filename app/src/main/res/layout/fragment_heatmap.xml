<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🔥 HEADER NEGRO -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MAPA DE CALOR"
        android:textColor="@android:color/white"
        android:background="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="16dp" />

    <!-- CONTENIDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_margin="16dp"
            android:padding="16dp"
            android:background="@android:color/white"
            android:elevation="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- TITULO -->
            <TextView
                android:text="Análisis de Ocupación"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <!-- 🔥 BARRA 1 -->
            <TextView
                android:text="Centro"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:progress="80"
                android:progressDrawable="@drawable/progress_custom"
                android:layout_marginBottom="12dp"/>

            <!-- 🔥 BARRA 2 -->
            <TextView
                android:text="Plaza"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:progress="80"
                android:progressDrawable="@drawable/progress_custom"
                android:layout_marginBottom="12dp"/>

            <!-- 🔥 BARRA 3 -->
            <TextView
                android:text="Norte"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:progress="80"
                android:progressDrawable="@drawable/progress_custom"
                android:layout_marginBottom="12dp"/>

            <!-- 🔥 SECCION RENTABILIDAD -->
            <TextView
                android:text="Parqueaderos Más Rentables"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- LISTA -->
            <TextView
                android:text="1. Centro - $18,450"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="2. Plaza - $15,230"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="3. Norte - $12,890"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>