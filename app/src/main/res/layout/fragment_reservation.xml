<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva Reserva"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/azul_oscuro"
            android:layout_marginBottom="20dp"/>

        <!-- CARD PARQUEADERO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            android:backgroundTint="@color/celeste"
            android:layout_marginBottom="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parqueadero"
                    android:textColor="#5A6B7B"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/txtParkingName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parqueadero Centro"
                    android:textStyle="bold"
                    android:textSize="24sp"
                    android:textColor="@color/azul_oscuro"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- FECHA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha y Hora de Entrada"
            android:textStyle="bold"
            android:textColor="#4E5D6C"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etFechaHora"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="dd/mm/aaaa --:--"
            android:paddingHorizontal="16dp"
            android:textSize="18sp"
            android:background="@drawable/bg_input"
            android:focusable="false"
            android:layout_marginBottom="24dp"/>

        <!-- DURACIÓN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duración Estimada"
            android:textStyle="bold"
            android:textColor="#4E5D6C"
            android:textSize="18sp"
            android:layout_marginBottom="10dp"/>

        <Spinner
            android:id="@+id/spinnerDuracion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- SUBTOTAL -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            android:backgroundTint="#F5F5F5"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Subtotal:"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="@color/azul_oscuro"/>

                <TextView
                    android:id="@+id/txtSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$4.00"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#111111"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- BOTÓN -->
        <Button
            android:id="@+id/btnContinuar"
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:text="Continuar"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/azul_medio"/>

    </LinearLayout>

</ScrollView>