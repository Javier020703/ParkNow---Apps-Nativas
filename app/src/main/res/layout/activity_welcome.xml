<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bienvenido_a_parknow"
            android:textColor="#023E8A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_marginTop="20dp"/>

        <!-- SUBTITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/encuentra_reserva_y_paga_tu_parqueadero_f_cilmente"
            android:textColor="#0077B6"
            android:textSize="16sp"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="30dp"/>

        <!-- CARD 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_feature_card"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="#023E8A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/encuentra_espacios_f_cilmente"
                android:textStyle="bold"
                android:textColor="#023E8A"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ubica_parqueaderos_cercanos_en_segundos"
                android:textAlignment="center"
                android:gravity="center"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- CARD 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_feature_card"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#023E8A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reserva_en_tiempo_real"
                android:textStyle="bold"
                android:textColor="#023E8A"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/asegura_tu_cupo_antes_de_llegar"
                android:textAlignment="center"
                android:gravity="center"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- CARD 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_feature_card"
            android:padding="20dp"
            android:layout_marginBottom="30dp"
            android:elevation="4dp">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                app:tint="#023E8A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pago_digital_seguro"
                android:textStyle="bold"
                android:textColor="#023E8A"
                android:textSize="18sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/paga_desde_tu_celular_de_forma_r_pida"
                android:textAlignment="center"
                android:gravity="center"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- BOTON -->
        <Button
            android:id="@+id/btnComenzar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/comenzar"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0077B6"
            android:layout_marginBottom="30dp"/>

    </LinearLayout>

</ScrollView>