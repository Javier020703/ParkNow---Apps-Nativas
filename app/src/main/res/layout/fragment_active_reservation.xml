<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reserva Activa"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/azul_oscuro"
            android:layout_marginBottom="24dp"/>

        <!-- CARD CÓDIGO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            android:backgroundTint="@color/azul_medio">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp">

                <!-- ESTADO -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- CIRCULO VERDE -->
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_green_dot"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVA"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#DFF6E4"
                        android:layout_marginStart="8dp"/>

                </LinearLayout>

                <!-- CODIGO -->
                <TextView
                    android:id="@+id/txtCodigoReserva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PKN-8542"
                    android:textSize="38sp"
                    android:textStyle="bold"
                    android:textColor="@color/blanco"
                    android:layout_marginTop="22dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- CARD INFORMACIÓN -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:backgroundTint="#F7F9FC"
            android:layout_marginTop="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- PARQUEADERO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Parqueadero"
                        android:textColor="#666666"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/txtParking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Centro"
                        android:textStyle="bold"
                        android:textColor="@color/azul_oscuro"
                        android:textSize="16sp"/>

                </LinearLayout>

                <!-- ESPACIO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Espacio"
                        android:textColor="#666666"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/txtEspacio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A-15"
                        android:textStyle="bold"
                        android:textColor="@color/azul_oscuro"
                        android:textSize="16sp"/>

                </LinearLayout>

                <!-- ENTRADA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Entrada"
                        android:textColor="#666666"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/txtEntrada"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14:30 PM"
                        android:textStyle="bold"
                        android:textColor="@color/azul_oscuro"
                        android:textSize="16sp"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- TIEMPO RESTANTE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            android:backgroundTint="#F7F9FC"
            android:layout_marginTop="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiempo restante"
                    android:textSize="16sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/txtTiempoRestante"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1h 45m"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="@color/azul_oscuro"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>