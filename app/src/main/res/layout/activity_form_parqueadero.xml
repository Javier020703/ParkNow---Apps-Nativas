<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--  BARRA SUPERIOR -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/nuevo_parqueadero"
        android:textColor="@android:color/white"
        android:background="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!--  CARD -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- HEADER -->
                <TextView
                    android:text="@string/registrar_parqueadero"
                    android:textColor="@android:color/white"
                    android:background="@color/primary"
                    android:padding="12dp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- INPUT NOMBRE -->
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/nombre"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginTop="12dp"/>

                <!-- DIRECCIÓN -->
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/direcci_n"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

                <!-- ESPACIOS -->
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/cantidad_de_espacios"
                    android:inputType="number"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

                <!-- TARIFA -->
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/tarifa_por_hora"
                    android:inputType="numberDecimal"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

                <!-- SUBTITULO -->
                <TextView
                    android:text="@string/caracter_sticas"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginTop="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- CHECKBOXES -->
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vigilancia_24_7"/>

                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/techado"/>

                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/c_maras_de_seguridad"/>

                <!-- BOTÓN -->
                <Button
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/crear_parqueadero"
                    android:backgroundTint="@color/primary"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>