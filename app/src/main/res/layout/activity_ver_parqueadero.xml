<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- CARD PRINCIPAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="6dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parqueadero"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvDireccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dirección"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/tvEspacios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Espacios: 0"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tvTarifa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tarifa: $0"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado: ACTIVO"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- BOTON EDITAR -->
        <Button
            android:id="@+id/btnEditar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Editar Parqueadero"
            android:layout_marginTop="20dp"
            android:backgroundTint="#5B4DBB"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>