<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--  BARRA NEGRA SUPERIOR -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/detalle_parqueadero"
        android:textColor="@android:color/white"
        android:background="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!--  CARD PRINCIPAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="6dp"
                android:orientation="vertical">

                <!-- HEADER -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/informaci_n_del_parqueadero"
                    android:textColor="@android:color/white"
                    android:background="@color/primary"
                    android:padding="12dp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>

                <!-- NOMBRE -->
                <TextView
                    android:id="@+id/tvNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/parqueadero"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="12dp"/>

                <!-- DIRECCIÓN -->
                <TextView
                    android:id="@+id/tvDireccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/direcci_n"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp"/>

                <!-- ESPACIOS -->
                <TextView
                    android:id="@+id/tvEspacios"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/espacios_0"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp"/>

                <!-- TARIFA -->
                <TextView
                    android:id="@+id/tvTarifa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tarifa_0"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp"/>

                <!-- ESTADO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/estado_activo"
                    android:textColor="@color/green"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

            <!-- BOTÓN -->
            <Button
                android:id="@+id/btnEditar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/editar_parqueadero"
                android:backgroundTint="@color/primary"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>