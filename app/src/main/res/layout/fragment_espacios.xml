<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🔥 TITULO NEGRO (TIPO ADMIN) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ESPACIOS"
        android:textColor="@android:color/white"
        android:background="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="16dp" />

    <!-- 🔍 BUSCADOR -->
    <EditText
        android:id="@+id/etBuscarEspacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Buscar Parqueadero..."
        android:layout_margin="12dp"
        android:padding="12dp"
        android:background="@drawable/bg_input" />

    <!-- CONTENIDO -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- CARD -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:elevation="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- HEADER AZUL -->
            <TextView
                android:text="Espacios en Tiempo Real"
                android:textColor="@android:color/white"
                android:background="@color/primary"
                android:padding="12dp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- TITULO -->
            <TextView
                android:text="Estado de Espacios"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- RECYCLER -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerEspacios"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="200dp"/>

            <!-- CONTADOR -->
            <TextView
                android:id="@+id/tvResumen"
                android:text="Libres: 0 | Ocupados: 0 | Reservados: 0"
                android:textAlignment="center"
                android:background="#D6EAF8"
                android:padding="10dp"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- BOTON -->
            <Button
                android:id="@+id/btnActualizar"
                android:text="Actualizar Estado"
                android:backgroundTint="@color/primary"
                android:textColor="@android:color/white"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>