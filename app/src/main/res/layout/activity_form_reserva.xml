<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reservas"
        android:textColor="@android:color/white"
        android:background="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:paddingTop="32dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="@string/crear_reserva"
                    android:textColor="@android:color/white"
                    android:background="@color/primary"
                    android:padding="12dp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etCliente"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/nombre_del_cliente"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginTop="12dp" />

                <EditText
                    android:id="@+id/etParqueadero"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/parqueadero"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginTop="10dp" />

                <EditText
                    android:id="@+id/etEspacio"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/espacio_ej_a_15"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginTop="10dp" />

                <EditText
                    android:id="@+id/etHora"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/hora_ej_14_30"
                    android:inputType="time"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:layout_marginTop="10dp" />

                <Button
                    android:id="@+id/btnGuardar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/guardar_reserva"
                    android:backgroundTint="@color/primary"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="18dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>