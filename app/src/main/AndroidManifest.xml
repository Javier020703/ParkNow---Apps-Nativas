<?xml version="1.0" encoding="utf-8"?>
<manifest package="com.example.parknow1"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ParkNow1">

        <!-- 🔥 ADMIN (ENTRY POINT) -->
        <activity
            android:name=".ui.admin.AdminActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- 🔹 RESERVAS -->
        <activity android:name=".ui.admin.reservations.FormReservaActivity"/>
        <activity android:name=".ui.admin.reservations.DetalleReservaActivity"/>

        <!-- 🔹 PARQUEADEROS -->
        <activity android:name=".ui.admin.activities.FormParqueaderoActivity"/>
        <activity android:name=".ui.admin.activities.VerParqueaderoActivity"/>

        <!-- 🔹 USUARIOS -->
        <activity android:name=".ui.admin.users.FormUsuarioActivity"/>
        <activity android:name=".ui.admin.users.DetalleUsuarioActivity"/>

        <!-- 🔹 TARIFAS -->
        <activity android:name=".ui.admin.tarifas.FormTarifaActivity"/>

        <!-- 🔹 USER APP -->
        <activity android:name=".ui.user.PruebaActivity"/>

        <!-- 🔹 MAIN (NO launcher) -->
        <activity android:name=".MainActivity"/>

    </application>

</manifest>